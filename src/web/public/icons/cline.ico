rty="og:image:height" content="630"/><meta property="og:image:alt" content="Cline Bot Inc"/><meta property="og:type" content="website"/><meta name="twitter:card" content="summary_large_image"/><meta name="twitter:title" content="Cline - AI Coding, Open Source and Uncompromised"/><meta name="twitter:description" content="Open-source AI coding agent with Plan/Act modes, MCP integration, and terminal-first workflows. Trusted by 5M+ developers worldwide."/><meta name="twitter:image" content="https://cline.bot/cline_og_img.png"/><meta name="twitter:image:alt" content="Cline Bot Inc"/><link rel="icon" href="/assets/branding/favicons/favicon-16x16.png" sizes="16x16" type="image/png"/><link rel="icon" href="/assets/branding/favicons/favicon-32x32.png" sizes="32x32" type="image/png"/><link rel="icon" href="/assets/branding/favicons/favicon-256x256.png" sizes="256x256" type="image/png"/><link rel="apple-touch-icon" href="/assets/branding/favicons/apple-touch-icon.png" sizes="180x180" type="image/png"/><noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1679462889454793&amp;ev=PageView&amp;noscript=1"/></noscript><script type="application/ld+json">{"@context":"https://schema.org","@type":"SoftwareApplication","name":"Cline","applicationCategory":"DeveloperApplication","operatingSystem":"All","description":"An autonomous AI coding assistant for VS Code with Plan/Act modes, terminal execution, file editing, and Model Context Protocol for custom tools","offers":{"@type":"Offer","price":"0.00","priceCurrency":"USD"},"softwareHelp":{"@type":"CreativeWork","url":"https://github.com/cline/cline"},"applicationSuite":"Visual Studio Code","featureList":["Plan/Act modes for structured development","Model Context Protocol (MCP) for extensibility","Terminal command execution","Automated file editing","Browser automation for testing","Multi-model AI support","Real-time debugging capabilities"],"keywords":"AI coding assistant, autonomous coding agent, GitHub Copilot alternative, VS Code AI extension, MCP protocol"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is Cline?","acceptedAnswer":{"@type":"Answer","text":"Cline is an open-source AI coding assistant for VS Code that features dual Plan/Act modes, terminal execution capabilities, and the Model Context Protocol (MCP) for custom tool creation. It serves as a fully collaborative AI partner for developers."}},{"@type":"Question","name":"How is Cline different from GitHub Copilot?","acceptedAnswer":{"@type":"Answer","text":"Cline is open-source and offers unique features like Plan/Act modes for structured development, terminal command execution, browser automation for testing, and the Model Context Protocol (MCP) for creating custom development tools."}},{"@type":"Question","name":"What programming languages does Cline support?","acceptedAnswer":{"@type":"Answer","text":"Cline supports all major programming languages and frameworks through its AI models and can execute terminal commands, edit files, and automate browser testing across different technology stacks."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"Cline Bot Inc","url":"https://cline.bot","logo":"https://cline.bot/assets/branding/logos/cline-logo.png","description":"Developer of Cline, an open-source AI coding assistant for VS Code","sameAs":["https://github.com/cline/cline","https://discord.gg/cline","https://x.com/cline"],"contactPoint":{"@type":"ContactPoint","contactType":"Customer Support","url":"https://cline.bot/contact"}}</script><script src="/_next/static/chunks/polyfills-42372ed130431b0a.js" noModule=""></script></head><body class="__variable_f367f3 __variable_dd5b2f __variable_2e38ea __variable_0d7163 font-sans overflow-x-hidden selection:bg-brand-purple selection:text-white"><div hidden=""><!--$--><!--/$--></div><noscript><iframe sr